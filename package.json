    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "exifr": "^7.1.3",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "marked": "^18.0.5",
    "nanoid": "^5.1.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remove-markdown": "^0.6.4",
    "twitter-text": "^3.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
